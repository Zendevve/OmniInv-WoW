<Bindings>
    <Binding name="GUDA_TOGGLE_BAGS" header="GUDA">
        -- Use safe global wrapper that defers until addon is ready
        Guda_ToggleBags()
    </Binding>
    <Binding name="GUDA_TOGGLE_BANK" header="GUDA">
        -- Use safe global wrapper that defers until addon is ready
        Guda_ToggleBank()
    </Binding>
    <!-- The actual action is wired via SetBindingClick at runtime so the key
         press triggers a secure click on the quest-bar button (type="item")
         rather than a tainted Lua UseContainerItem call. -->
    <Binding name="GUDA_USE_QUEST_ITEM_1" header="GUDA">
    </Binding>
    <Binding name="GUDA_USE_QUEST_ITEM_2" header="GUDA">
    </Binding>
</Bindings>
